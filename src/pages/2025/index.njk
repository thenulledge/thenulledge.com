---
layout: base
title: '2025 Events - nullEDGE'
description: 'nullEDGE 2025 - A full day of technical sessions and community'
permalink: /2025/index.html
---

<section class="year-index">
  <div class="container">
    <header class="year-header">
      <h1>2025 Events</h1>
      <p class="year-description">Looking back at our first year of community-driven ServiceNow learning.</p>
    </header>
    
    <div class="events-grid">
      {% for event in events2025Array %}
      <article class="event-card event-card-past">
        <span class="event-status-badge event-status-completed">
          <i class="fa-solid fa-check-circle"></i>
          Completed
        </span>
        
        <h2 class="event-name">
          <a href="{{ event.url }}/">{{ event.name }}</a>
        </h2>
        
        <div class="event-meta">
          <div class="event-date">
            <i class="fa-solid fa-calendar"></i>
            <span>{{ event.when.start | formatDate('MMMM D, YYYY') }}</span>
          </div>
          <div class="event-type">
            <span class="type-badge type-conference">Full Day Conference</span>
          </div>
        </div>
        
        <p class="event-description">{{ event.description }}</p>
        
        {% if event.stats %}
        <div class="event-stats">
          <div class="stat-item">
            <span class="stat-value">{{ event.stats.attendees }}</span>
            <span class="stat-label">Attendees</span>
          </div>
          <div class="stat-item">
            <span class="stat-value">{{ event.stats.sessions }}</span>
            <span class="stat-label">Sessions</span>
          </div>
          <div class="stat-item">
            <span class="stat-value">{{ event.stats.sponsors }}</span>
            <span class="stat-label">Sponsors</span>
          </div>
        </div>
        {% endif %}
        
        <a href="{{ event.url }}/" class="event-link">
          View Conference
          <i class="fa-solid fa-arrow-right"></i>
        </a>
      </article>
      {% endfor %}
    </div>
    
    <div class="year-navigation">
      <a href="/events/" class="btn btn-outline">
        <i class="fa-solid fa-clock-rotate-left"></i>
        All Events
      </a>
      <a href="/2026/" class="btn btn-primary">
        2026 Events
        <i class="fa-solid fa-arrow-right"></i>
      </a>
    </div>
  </div>
</section>

<style>
  .year-index {
    padding: 4rem 1rem;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .year-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .year-header h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }
  
  .year-description {
    font-size: 1.25rem;
    color: hsl(var(--muted-foreground));
    max-width: 600px;
    margin: 0 auto;
  }
  
  /* Events Grid */
  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }
  
  .event-card {
    position: relative;
    padding: 2rem;
    background: hsl(var(--card));
    border: 2px solid hsl(var(--border));
    border-radius: var(--radius);
    transition: all 0.2s;
  }
  
  .event-card:hover {
    border-color: hsl(var(--primary));
    box-shadow: 0 8px 16px hsl(var(--primary) / 0.1);
  }
  
  .event-card-past {
    opacity: 0.7;
    background: hsl(var(--muted) / 0.3);
  }
  
  .event-card-past:hover {
    opacity: 0.9;
  }
  
  .event-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: calc(var(--radius) - 4px);
    font-size: var(--size-step--2);
    font-weight: 600;
    margin-bottom: 1rem;
  }
  
  .event-status-completed {
    background: hsl(var(--accent) / 0.5);
    color: hsl(var(--accent-foreground));
  }
  
  .event-name {
    font-size: var(--size-step-1);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  
  .event-name a {
    color: inherit;
    text-decoration: none;
  }
  
  .event-name a:hover {
    color: hsl(var(--primary));
  }
  
  .event-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-size: var(--size-step--1);
  }
  
  .event-date {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: hsl(var(--muted-foreground));
  }
  
  .event-date i {
    color: hsl(var(--primary));
  }
  
  .type-badge {
    display: inline-flex;
    padding: 0.25rem 0.75rem;
    border-radius: calc(var(--radius) - 4px);
    font-size: var(--size-step--2);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.025em;
  }
  
  .type-conference {
    background: hsl(var(--primary));
    color: hsl(var(--primary-foreground));
  }
  
  .event-description {
    color: hsl(var(--muted-foreground));
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  
  /* Event Stats */
  .event-stats {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: hsl(var(--muted) / 0.3);
    border-radius: var(--radius);
  }
  
  .stat-item {
    text-align: center;
  }
  
  .stat-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: hsl(var(--primary));
  }
  
  .stat-label {
    font-size: var(--size-step--2);
    color: hsl(var(--muted-foreground));
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .event-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: hsl(var(--primary));
    font-weight: 600;
    text-decoration: none;
  }
  
  .event-link:hover {
    text-decoration: underline;
  }
  
  /* Year Navigation */
  .year-navigation {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  .year-navigation .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }
  
  .year-navigation .btn-outline {
    border: 2px solid hsl(var(--border));
    color: hsl(var(--foreground));
  }
  
  .year-navigation .btn-outline:hover {
    border-color: hsl(var(--primary));
    color: hsl(var(--primary));
  }
  
  .year-navigation .btn-primary {
    background: hsl(var(--primary));
    color: hsl(var(--primary-foreground));
  }
  
  .year-navigation .btn-primary:hover {
    background: hsl(var(--primary) / 0.9);
  }
  
  @media (max-width: 768px) {
    .year-index {
      padding: 2rem 1rem;
    }
    
    .events-grid {
      grid-template-columns: 1fr;
    }
    
    .event-stats {
      gap: 1rem;
    }
    
    .stat-value {
      font-size: 1.25rem;
    }
  }
</style>
