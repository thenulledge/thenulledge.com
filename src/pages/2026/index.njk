---
layout: base
title: '2026 Events - nullEDGE'
description: 'All nullEDGE events for 2026 - from networking to full-day conferences'
permalink: /2026/index.html
---

<section class="year-index">
  <div class="container">
    <header class="year-header">
      <h1>2026 Event Series</h1>
      <p class="year-description">Four events throughout 2026, connecting ServiceNow professionals around the globe.</p>
    </header>
    
    <div class="events-grid">
      {% for event in events2026Array %}
      {% set isPast = event | isPastEvent %}
      <article class="event-card {% if isPast %}event-card-past{% endif %}">
        {% if isPast %}
        <span class="event-status-badge event-status-completed">
          <i class="fa-solid fa-check-circle"></i>
          Completed
        </span>
        {% endif %}
        
        <h2 class="event-name">
          <a href="{{ event.url }}/">{{ event.name }}</a>
        </h2>
        
        <div class="event-meta">
          <div class="event-date">
            <i class="fa-solid fa-calendar"></i>
            <span>{{ event.when.start | formatDateShort(event.timezone) | safe }}</span>
          </div>
          <div class="event-type">
            {% if event.type == 'networking' %}
              <span class="type-badge type-networking">Networking Event</span>
            {% endif %}
            {% if event.type == 'sessions' %}
              <span class="type-badge type-sessions">{{ event.sessionCount }} Sessions</span>
            {% endif %}
            {% if event.type == 'full-day' %}
              <span class="type-badge type-conference">Full Day Conference</span>
            {% endif %}
          </div>
        </div>
        
        <p class="event-description">{{ event.description }}</p>
        
        <a href="{{ event.url }}/" class="event-link">
          {% if isPast %}View Event{% else %}View Details{% endif %}
          <i class="fa-solid fa-arrow-right"></i>
        </a>
      </article>
      {% endfor %}
    </div>
    
    {# Sponsors Section - Shows by tier #}
    {% set hasAnySponsors = false %}
    {% for event in events2026Array %}
      {% if event.sponsors %}
        {% if (event.sponsors.elite and event.sponsors.elite.length > 0) or 
              (event.sponsors.premium and event.sponsors.premium.length > 0) or 
              (event.sponsors.minimum and event.sponsors.minimum.length > 0) %}
          {% set hasAnySponsors = true %}
        {% endif %}
      {% endif %}
    {% endfor %}
    
    {% if hasAnySponsors %}
    <section class="year-sponsors">
      <h2 class="sponsors-title">2026 Sponsors</h2>
      
      {# Collect unique sponsors by tier across all events #}
      {% set eliteSponsors = [] %}
      {% set premiumSponsors = [] %}
      {% set minimumSponsors = [] %}
      
      {% for event in events2026Array %}
        {% if event.sponsors %}
          {% if event.sponsors.elite %}
            {% for sponsor in event.sponsors.elite %}
              {% if sponsor not in eliteSponsors %}
                {% set _ = eliteSponsors.push(sponsor) %}
              {% endif %}
            {% endfor %}
          {% endif %}
          {% if event.sponsors.premium %}
            {% for sponsor in event.sponsors.premium %}
              {% if sponsor not in premiumSponsors and sponsor not in eliteSponsors %}
                {% set _ = premiumSponsors.push(sponsor) %}
              {% endif %}
            {% endfor %}
          {% endif %}
          {% if event.sponsors.minimum %}
            {% for sponsor in event.sponsors.minimum %}
              {% if sponsor not in minimumSponsors and sponsor not in eliteSponsors and sponsor not in premiumSponsors %}
                {% set _ = minimumSponsors.push(sponsor) %}
              {% endif %}
            {% endfor %}
          {% endif %}
        {% endif %}
      {% endfor %}
      
      {# Elite Tier #}
      {% if eliteSponsors.length > 0 %}
      <div class="sponsor-tier tier-elite">
        <h3 class="tier-label">
          <span class="tier-badge tier-badge-elite">Elite</span>
        </h3>
        <div class="sponsors-grid tier-elite-grid">
          {% for sponsorName in eliteSponsors %}
            {%- set company = companies[sponsorName] %}
            {% if company %}
            <a href="{{ company.website }}" target="_blank" rel="noopener noreferrer" class="sponsor-item sponsor-elite">
              <img src="{{ company.image }}" alt="{{ sponsorName }}" loading="lazy">
            </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      {% endif %}
      
      {# Premium Tier #}
      {% if premiumSponsors.length > 0 %}
      <div class="sponsor-tier tier-premium">
        <h3 class="tier-label">
          <span class="tier-badge tier-badge-premium">Premium</span>
        </h3>
        <div class="sponsors-grid tier-premium-grid">
          {% for sponsorName in premiumSponsors %}
            {%- set company = companies[sponsorName] %}
            {% if company %}
            <a href="{{ company.website }}" target="_blank" rel="noopener noreferrer" class="sponsor-item sponsor-premium">
              <img src="{{ company.image }}" alt="{{ sponsorName }}" loading="lazy">
            </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      {% endif %}
      
      {# Supporters - no label, just smaller logos #}
      {% if minimumSponsors.length > 0 %}
      <div class="sponsor-tier tier-supporters">
        <div class="sponsors-grid tier-supporters-grid">
          {% for sponsorName in minimumSponsors %}
            {%- set company = companies[sponsorName] %}
            {% if company %}
            <a href="{{ company.website }}" target="_blank" rel="noopener noreferrer" class="sponsor-item sponsor-supporter">
              <img src="{{ company.image }}" alt="{{ sponsorName }}" loading="lazy">
            </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      {% endif %}
    </section>
    {% else %}
    <section class="year-sponsors year-sponsors-empty">
      <h2 class="sponsors-title">Become a 2026 Sponsor</h2>
      <p class="sponsors-description">Help us make nullEDGE 2026 even better. Join our community of sponsors.</p>
      <a href="/sponsors/" class="btn btn-primary">View Sponsorship Opportunities</a>
    </section>
    {% endif %}

    <div class="year-navigation">
      <a href="/events/" class="btn btn-outline">
        <i class="fa-solid fa-clock-rotate-left"></i>
        All Events
      </a>
      <a href="/" class="btn btn-primary">
        Back to Home
      </a>
    </div>
  </div>
</section>

<style>
  .year-index {
    padding: 4rem 1rem;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .year-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .year-header h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }
  
  .year-description {
    font-size: 1.25rem;
    color: hsl(var(--muted-foreground));
    max-width: 600px;
    margin: 0 auto;
  }
  
  /* Events Grid */
  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }
  
  .event-card {
    position: relative;
    padding: 2rem;
    background: hsl(var(--card));
    border: 2px solid hsl(var(--border));
    border-radius: var(--radius);
    transition: all 0.2s;
  }
  
  .event-card:hover {
    border-color: hsl(var(--primary));
    box-shadow: 0 8px 16px hsl(var(--primary) / 0.1);
  }
  
  .event-card-past {
    opacity: 0.7;
    background: hsl(var(--muted) / 0.3);
  }
  
  .event-card-past:hover {
    opacity: 0.9;
  }
  
  .event-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: calc(var(--radius) - 4px);
    font-size: var(--size-step--2);
    font-weight: 600;
    margin-bottom: 1rem;
  }
  
  .event-status-completed {
    background: hsl(var(--accent) / 0.5);
    color: hsl(var(--accent-foreground));
  }
  
  .event-name {
    font-size: var(--size-step-1);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  
  .event-name a {
    color: inherit;
    text-decoration: none;
  }
  
  .event-name a:hover {
    color: hsl(var(--primary));
  }
  
  .event-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-size: var(--size-step--1);
  }
  
  .event-date {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: hsl(var(--muted-foreground));
  }
  
  .event-date i {
    color: hsl(var(--primary));
  }
  
  .type-badge {
    display: inline-flex;
    padding: 0.25rem 0.75rem;
    border-radius: calc(var(--radius) - 4px);
    font-size: var(--size-step--2);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.025em;
  }
  
  .type-networking {
    background: hsl(var(--primary) / 0.1);
    color: hsl(var(--primary));
  }
  
  .type-sessions {
    background: hsl(var(--accent) / 0.5);
    color: hsl(var(--accent-foreground));
  }
  
  .type-conference {
    background: hsl(var(--primary));
    color: hsl(var(--primary-foreground));
  }
  
  .event-description {
    color: hsl(var(--muted-foreground));
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  
  .event-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: hsl(var(--primary));
    font-weight: 600;
    text-decoration: none;
  }
  
  .event-link:hover {
    text-decoration: underline;
  }
  
  /* Year Navigation */
  .year-navigation {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  .year-navigation .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }
  
  .year-navigation .btn-outline {
    border: 2px solid hsl(var(--border));
    color: hsl(var(--foreground));
  }
  
  .year-navigation .btn-outline:hover {
    border-color: hsl(var(--primary));
    color: hsl(var(--primary));
  }
  
  .year-navigation .btn-primary {
    background: hsl(var(--primary));
    color: hsl(var(--primary-foreground));
  }
  
  .year-navigation .btn-primary:hover {
    background: hsl(var(--primary) / 0.9);
  }
  
  /* Year Sponsors */
  .year-sponsors {
    margin: 4rem 0;
    padding: 2rem;
    background: hsl(var(--muted) / 0.2);
    border-radius: var(--radius);
    border: 1px solid hsl(var(--border));
    text-align: center;
  }

  .year-sponsors-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .sponsors-title {
    font-size: var(--size-step-1);
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .sponsors-description {
    color: hsl(var(--muted-foreground));
    margin-bottom: 1rem;
  }

  /* Tier Labels */
  .sponsor-tier {
    margin-bottom: 2.5rem;
  }

  .tier-label {
    margin-bottom: 1rem;
  }

  .tier-badge {
    display: inline-flex;
    padding: 0.375rem 1rem;
    border-radius: calc(var(--radius) - 2px);
    font-size: var(--size-step--2);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .tier-badge-elite {
    background: linear-gradient(135deg, hsl(45 90% 50%), hsl(35 90% 45%));
    color: #000;
  }

  .tier-badge-premium {
    background: hsl(var(--primary));
    color: hsl(var(--primary-foreground));
  }

  .sponsors-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: center;
    justify-content: center;
  }

  .sponsor-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: white;
    border-radius: var(--radius);
    border: 2px solid hsl(var(--border));
    transition: all 0.2s;
  }

  .sponsor-item:hover {
    border-color: hsl(var(--primary));
    box-shadow: 0 8px 24px hsl(var(--primary) / 0.15);
    transform: translateY(-2px);
  }

  /* Elite - largest */
  .tier-elite-grid {
    gap: 3rem;
  }
  .sponsor-elite img {
    max-width: 240px;
    max-height: 100px;
  }

  /* Premium - medium */
  .tier-premium-grid {
    gap: 2.5rem;
  }
  .sponsor-premium img {
    max-width: 200px;
    max-height: 80px;
  }

  /* Supporters - no label */
  .tier-supporters-grid {
    gap: 1.5rem;
  }
  .sponsor-supporter img {
    max-width: 140px;
    max-height: 60px;
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .year-index {
      padding: 2rem 1rem;
    }

    .events-grid {
      grid-template-columns: 1fr;
    }

    .sponsors-grid {
      gap: 1rem;
    }

    .sponsor-elite img {
      max-width: 180px;
      max-height: 80px;
    }

    .sponsor-premium img {
      max-width: 160px;
      max-height: 70px;
    }

    .sponsor-supporter img {
      max-width: 110px;
      max-height: 50px;
    }
  }
</style>
