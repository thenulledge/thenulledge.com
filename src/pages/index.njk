---
layout: base
permalink: /index.html
title: 'nullEDGE - Free ServiceNow Conference'
description: 'Join 1,000+ ServiceNow folks for deep technical sessions, real code, and zero sales pitches. 100% free virtual conference.'
ogImage: '/assets/og-images/homepage-preview.png'
ogImageAlt: 'nullEDGE 2026 - Free ServiceNow Conference - October 16, 2026 - 4 Virtual Events - Join 1,000+ ServiceNow Professionals'
---
{% set event2026 = events['2026'].nullEDGE %}

{% from "partials/hero.njk" import hero %}

{{ hero(
  title="Master ServiceNow with Free Expert Sessions",
  subtitle="Join 1,000+ developers learning real-world techniques—no sales pitches, just code. Four free events in 2026.",
  primaryCtaText="View 2026 Events",
  primaryCtaLink="/2026/"
) }}

{# Benefits Section #}
<section class="benefits-section">
  <div class="container">
    <h2 class="section-title">What You'll Get</h2>
    <div class="benefits-grid">
      <div class="benefit-card">
        <i class="fa-solid fa-code"></i>
        <h3>Real Code</h3>
        <p>See actual implementations, not slide decks. Copy-paste ready examples.</p>
      </div>
      <div class="benefit-card">
        <i class="fa-solid fa-users"></i>
        <h3>Expert Speakers</h3>
        <p>Learn from ServiceNow architects, MVPs, and practitioners in the trenches.</p>
      </div>
      <div class="benefit-card">
        <i class="fa-solid fa-handshake"></i>
        <h3>Community</h3>
        <p>Connect with 1,000+ professionals. Ask questions, share solutions.</p>
      </div>
      <div class="benefit-card">
        <i class="fa-solid fa-video"></i>
        <h3>Watch Anytime</h3>
        <p>All sessions recorded. Rewatch at your own pace.</p>
      </div>
    </div>
  </div>
</section>

{% from "partials/events-timeline.njk" import eventsTimeline %}
{{ eventsTimeline(
  title="2026 Event Series",
  subtitle="Four events throughout 2026, connecting ServiceNow folks around the globe.",
  year="2026",
  eventsData=events['2026']
) }}

<section class="social-proof-section">
  <div class="container">
    <p class="social-proof-text">
      <i class="fa-solid fa-users"></i>
      Trusted by <strong>746 attendees</strong> from <strong>40+ countries</strong> in 2025
      <a href="/2025/" class="retro-link">View 2025 Retrospective →</a>
      <a href="https://www.youtube.com/watch?v=dU6JY136vTg" target="_blank" rel="noopener" class="retro-link">Watch 2025 Highlights →</a>
    </p>
  </div>
</section>

{# Featured Testimonials - using the same partial as conference page #}
{% set featuredTestimonials = testimonials | selectattr("featured") | list %}
{% if featuredTestimonials.length > 0 %}
  {% set testimonials = featuredTestimonials %}
  {% set testimonialsTitle = "What Attendees Say" %}
  {% set testimonialsSubtitle = "" %}
  {% include "partials/testimonials-section.njk" %}
{% endif %}

{# Sponsors Section with Tier Display #}
{% if event2026.sponsors %}
<section class="sponsors-tiered-section">
  <div class="container">
    <h2 class="section-title">Our 2026 Sponsors</h2>
    
    {# Elite Tier #}
    {% if event2026.sponsors.elite and event2026.sponsors.elite.length > 0 %}
    <div class="sponsor-tier tier-elite">
      <h3 class="tier-label">
        <span class="tier-badge tier-badge-elite">Elite</span>
      </h3>
      <div class="sponsors-grid tier-elite-grid">
        {% for sponsorName in event2026.sponsors.elite %}
          {%- set company = companies[sponsorName] %}
          {% if company %}
          <a href="{{ company.website }}" target="_blank" rel="noopener noreferrer" class="sponsor-item sponsor-elite">
            <img src="{{ company.image }}" alt="{{ sponsorName }}" loading="lazy">
          </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {% endif %}
    
    {# Premium Tier #}
    {% if event2026.sponsors.premium and event2026.sponsors.premium.length > 0 %}
    <div class="sponsor-tier tier-premium">
      <h3 class="tier-label">
        <span class="tier-badge tier-badge-premium">Premium</span>
      </h3>
      <div class="sponsors-grid tier-premium-grid">
        {% for sponsorName in event2026.sponsors.premium %}
          {%- set company = companies[sponsorName] %}
          {% if company %}
          <a href="{{ company.website }}" target="_blank" rel="noopener noreferrer" class="sponsor-item sponsor-premium">
            <img src="{{ company.image }}" alt="{{ sponsorName }}" loading="lazy">
          </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {% endif %}
    
      {# Supporters (formerly Minimum) - no label, just smaller logos #}
      {% if event2026.sponsors.minimum and event2026.sponsors.minimum.length > 0 %}
      <div class="sponsor-tier tier-supporters">
        <div class="sponsors-grid tier-supporters-grid">
          {% for sponsorName in event2026.sponsors.minimum %}
            {%- set company = companies[sponsorName] %}
            {% if company %}
            <a href="{{ company.website }}" target="_blank" rel="noopener noreferrer" class="sponsor-item sponsor-supporter">
              <img src="{{ company.image }}" alt="{{ sponsorName }}" loading="lazy">
            </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      {% endif %}
    
    <p class="sponsors-cta">
      <a href="/sponsors/" class="btn btn-outline">Become a Sponsor →</a>
    </p>
  </div>
</section>

{# Speaker CTA - for speakers, not attendees #}
<section class="speaker-cta-section">
  <div class="container">
    <h2>Share Your Expertise</h2>
    <p>Been working on something cool? Submit a session and teach the community.</p>
    <a href="/speak/" class="btn btn-primary">Submit a Session →</a>
  </div>
</section>
{% else %}
<section class="sponsors-section">
  <div class="container">
    <h2 class="section-title">Our Sponsors</h2>
    <p class="section-subtitle">Help us make nullEDGE 2026 even better. <a href="/sponsors/">Become a sponsor →</a></p>
  </div>
</section>
{% endif %}

<style>
  /* Lite YouTube Embed Styles */
  {% include "../assets/css/local/lite-youtube.css" %}

  /* Social Proof Section */
  .social-proof-section {
    padding: 2rem 1rem;
    background: hsl(var(--muted) / 0.3);
    border-top: 1px solid hsl(var(--border));
    border-bottom: 1px solid hsl(var(--border));
  }

  .social-proof-section .container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .social-proof-text {
    font-size: var(--size-step-0);
    color: hsl(var(--muted-foreground));
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .social-proof-text i {
    color: hsl(var(--primary));
  }

  .social-proof-text strong {
    color: hsl(var(--foreground));
  }

  .retro-link {
    color: hsl(var(--primary));
    text-decoration: none;
    font-weight: 500;
    margin-left: 0.5rem;
  }

  .retro-link:hover {
    text-decoration: underline;
  }

  /* Sponsors Section (when no sponsors yet) */
  .sponsors-section {
    padding: 4rem 1rem;
    text-align: center;
  }

  .sponsors-section .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .sponsors-section .section-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .sponsors-section .section-subtitle {
    font-size: var(--size-step-0);
    color: hsl(var(--muted-foreground));
  }

  .sponsors-section .section-subtitle a {
    color: hsl(var(--primary));
    text-decoration: none;
  }

  .sponsors-section .section-subtitle a:hover {
    text-decoration: underline;
  }

  /* Tiered Sponsors Section */
  .sponsors-tiered-section {
    padding: 4rem 1rem;
    background: hsl(var(--muted) / 0.2);
    border-top: 1px solid hsl(var(--border));
  }

  .sponsors-tiered-section .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .sponsors-tiered-section .section-title {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .sponsor-tier {
    margin-bottom: 2.5rem;
  }

  .tier-label {
    text-align: center;
    margin-bottom: 1rem;
  }

  .tier-badge {
    display: inline-flex;
    padding: 0.375rem 1rem;
    border-radius: calc(var(--radius) - 2px);
    font-size: var(--size-step--2);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .tier-badge-elite {
    background: linear-gradient(135deg, hsl(45 90% 50%), hsl(35 90% 45%));
    color: #000;
  }

  .tier-badge-premium {
    background: hsl(var(--primary));
    color: hsl(var(--primary-foreground));
  }

  .sponsors-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: center;
    justify-content: center;
  }

  .sponsor-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: white;
    border-radius: var(--radius);
    border: 2px solid hsl(var(--border));
    transition: all 0.2s;
  }

  .sponsor-item:hover {
    border-color: hsl(var(--primary));
    box-shadow: 0 8px 24px hsl(var(--primary) / 0.15);
    transform: translateY(-2px);
  }

  /* Elite sponsors - largest */
  .sponsor-elite img {
    max-width: 280px;
    max-height: 120px;
    object-fit: contain;
  }

  .tier-elite-grid {
    gap: 3rem;
  }

  /* Premium sponsors - medium */
  .sponsor-premium img {
    max-width: 220px;
    max-height: 90px;
    object-fit: contain;
  }

  .tier-premium-grid {
    gap: 2.5rem;
  }

  /* Supporters - smaller logos, no label */
  .sponsor-supporter img {
    max-width: 140px;
    max-height: 60px;
    opacity: 0.9;
    object-fit: contain;
  }

  .tier-supporters-grid {
    gap: 1.5rem;
  }

  .sponsors-cta {
    text-align: center;
    margin-top: 2rem;
  }

  /* Benefits Section */
  .benefits-section {
    padding: 4rem 1rem;
    background: hsl(var(--background));
  }

  .benefits-section .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .benefits-section .section-title {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .benefit-card {
    text-align: center;
    padding: 2rem;
    background: hsl(var(--card));
    border: 1px solid hsl(var(--border));
    border-radius: var(--radius);
    transition: all 0.2s;
  }

  .benefit-card:hover {
    border-color: hsl(var(--primary));
    box-shadow: 0 4px 12px hsl(var(--primary) / 0.1);
  }

  .benefit-card i {
    font-size: 2.5rem;
    color: hsl(var(--primary));
    margin-bottom: 1rem;
  }

  .benefit-card h3 {
    font-size: var(--size-step-0);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .benefit-card p {
    color: hsl(var(--muted-foreground));
    font-size: var(--size-step--1);
    line-height: 1.5;
  }

  /* Speaker CTA Section */
  .speaker-cta-section {
    padding: 4rem 1rem;
    background: hsl(var(--muted) / 0.2);
    border-top: 1px solid hsl(var(--border));
    text-align: center;
  }

  .speaker-cta-section .container {
    max-width: 800px;
    margin: 0 auto;
  }

  .speaker-cta-section h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .speaker-cta-section p {
    color: hsl(var(--muted-foreground));
    font-size: var(--size-step-0);
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .social-proof-text {
      flex-direction: column;
      gap: 0.5rem;
    }

    .retro-link {
      margin-left: 0;
    }

    .sponsor-elite img {
      max-width: 200px;
      max-height: 90px;
    }

    .sponsor-premium img {
      max-width: 160px;
      max-height: 70px;
    }

    .sponsor-supporter img {
      max-width: 110px;
      max-height: 50px;
    }

    .benefits-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script type="module">
  import 'https://cdn.jsdelivr.net/npm/@justinribeiro/lite-youtube@1.5.0/lite-youtube.js';
</script>
